rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isUser(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function hasTopLevelOwner(userId) {
      return !request.resource.data.keys().hasAny(['ownerUserID'])
        || request.resource.data.ownerUserID == userId;
    }

    function hasMetadataOwner(userId) {
      return !request.resource.data.keys().hasAny(['metadata'])
        || !request.resource.data.metadata.keys().hasAny(['ownerUserID'])
        || request.resource.data.metadata.ownerUserID == userId;
    }

    function noExternalActionWrite() {
      return !request.resource.data.keys().hasAny(['externalActionTaken'])
        || request.resource.data.externalActionTaken == false;
    }

    function noUnsafeBackendSyncStatusWrite() {
      return !request.resource.data.keys().hasAny(['syncStatus'])
        || request.resource.data.syncStatus == 'acknowledged';
    }

    function noBackendEventBypassWrite() {
      return !request.resource.data.keys().hasAny(['idempotencyKey']);
    }

    function noLocalFilePathWrite() {
      return !request.resource.data.keys().hasAny(['localRelativePath']);
    }

    function isSafeUserDocument(userId) {
      return hasTopLevelOwner(userId)
        && hasMetadataOwner(userId)
        && noExternalActionWrite()
        && noUnsafeBackendSyncStatusWrite()
        && noBackendEventBypassWrite()
        && noLocalFilePathWrite();
    }

    function hasProofAttachmentPath(userId, attachmentId) {
      return request.resource.data.storagePath == "users/" + userId + "/proofAttachments/" + attachmentId
        && request.resource.data.collectionPath == "users/" + userId + "/proofAttachments"
        && request.resource.data.documentPath == "users/" + userId + "/proofAttachments/" + attachmentId
        && request.resource.data.metadata.localID == attachmentId;
    }

    function hasSafeProofUploadReceipt(userId, attachmentId) {
      return (
          request.resource.data.uploadStatus == 'pendingUpload'
          && !request.resource.data.keys().hasAny(['uploadReceipt'])
        )
        || (
          request.resource.data.uploadStatus == 'uploaded'
          && request.resource.data.keys().hasAll(['uploadReceipt'])
          && request.resource.data.uploadReceipt.proofID == request.resource.data.proofID
          && request.resource.data.uploadReceipt.attachmentID == attachmentId
          && request.resource.data.uploadReceipt.storagePath == request.resource.data.storagePath
          && request.resource.data.uploadReceipt.contentType == request.resource.data.contentType
          && request.resource.data.uploadReceipt.byteCount == request.resource.data.byteCount
          && request.resource.data.uploadReceipt.status == 'uploaded'
          && request.resource.data.uploadReceipt.idempotencyKey == userId + "-" + attachmentId
        );
    }

    function isSafeProofAttachmentDocument(userId, attachmentId) {
      return isSafeUserDocument(userId)
        && hasProofAttachmentPath(userId, attachmentId)
        && request.resource.data.contentType is string
        && request.resource.data.byteCount is int
        && request.resource.data.uploadStatus in ['pendingUpload', 'uploaded']
        && hasSafeProofUploadReceipt(userId, attachmentId);
    }

    function isSafeProofRecordDocument(userId) {
      return isSafeUserDocument(userId)
        && !request.resource.data.keys().hasAny(['attachments']);
    }

    function hasDocumentPath(collectionName, userId, documentId) {
      return request.resource.data.collectionPath == "users/" + userId + "/" + collectionName
        && request.resource.data.documentPath == "users/" + userId + "/" + collectionName + "/" + documentId;
    }

    function isSafeCareerGraphDocument(collectionName, userId, documentId) {
      return isSafeUserDocument(userId)
        && hasDocumentPath(collectionName, userId, documentId);
    }

    function isKnownBackendEventKind(kind) {
      return kind in [
        'goalConfirmed',
        'questStarted',
        'proofReviewed',
        'proofClaimed',
        'outcomeLogged',
        'outcomeUpdated',
        'outcomeDeleted',
        'privacyUpdated',
        'syncPreviewPrepared'
      ];
    }

    function isKnownCareerOutcomeKind(kind) {
      return kind in [
        'applied',
        'interview',
        'rejection',
        'offer',
        'changedGoal',
        'other'
      ];
    }

    function isKnownCareerMemoryMode(mode) {
      return mode in ['localOnly', 'cloudReady', 'off'];
    }

    function hasSafeBackendEventSummary() {
      return request.resource.data.summary is map
        && request.resource.data.summary.keys().hasOnly([
          'targetRoleTitle',
          'questID',
          'questDay',
          'proofID',
          'outcomeID',
          'outcomeKind',
          'readinessOverall',
          'xp',
          'proofCount',
          'qualityAccepted',
          'qualityScore',
          'memoryMode',
          'shareWins',
          'documentCount',
          'proofUploadCount'
        ])
        && (!request.resource.data.summary.keys().hasAny(['targetRoleTitle'])
          || request.resource.data.summary.targetRoleTitle is string)
        && (!request.resource.data.summary.keys().hasAny(['questID'])
          || request.resource.data.summary.questID is string)
        && (!request.resource.data.summary.keys().hasAny(['questDay'])
          || request.resource.data.summary.questDay is int)
        && (!request.resource.data.summary.keys().hasAny(['proofID'])
          || request.resource.data.summary.proofID is string)
        && (!request.resource.data.summary.keys().hasAny(['outcomeID'])
          || request.resource.data.summary.outcomeID is string)
        && (!request.resource.data.summary.keys().hasAny(['outcomeKind'])
          || isKnownCareerOutcomeKind(request.resource.data.summary.outcomeKind))
        && (!request.resource.data.summary.keys().hasAny(['readinessOverall'])
          || request.resource.data.summary.readinessOverall is int)
        && (!request.resource.data.summary.keys().hasAny(['xp'])
          || request.resource.data.summary.xp is int)
        && (!request.resource.data.summary.keys().hasAny(['proofCount'])
          || request.resource.data.summary.proofCount is int)
        && (!request.resource.data.summary.keys().hasAny(['qualityAccepted'])
          || request.resource.data.summary.qualityAccepted is bool)
        && (!request.resource.data.summary.keys().hasAny(['qualityScore'])
          || request.resource.data.summary.qualityScore is int)
        && (!request.resource.data.summary.keys().hasAny(['memoryMode'])
          || isKnownCareerMemoryMode(request.resource.data.summary.memoryMode))
        && (!request.resource.data.summary.keys().hasAny(['shareWins'])
          || request.resource.data.summary.shareWins is bool)
        && (!request.resource.data.summary.keys().hasAny(['documentCount'])
          || request.resource.data.summary.documentCount is int)
        && (!request.resource.data.summary.keys().hasAny(['proofUploadCount'])
          || request.resource.data.summary.proofUploadCount is int);
    }

    function isSafeBackendEventDocument(userId, eventId) {
      return request.resource.data.keys().hasOnly([
          'schemaVersion',
          'eventID',
          'ownerUserID',
          'entityID',
          'kind',
          'syncStatus',
          'idempotencyKey',
          'occurredAt',
          'retryCount',
          'lastAttemptAt',
          'summary',
          'acceptedAt'
        ])
        && request.resource.data.schemaVersion == 1
        && request.resource.data.eventID == eventId
        && request.resource.data.ownerUserID == userId
        && request.resource.data.entityID is string
        && request.resource.data.entityID.size() > 0
        && request.resource.data.entityID.size() <= 128
        && request.resource.data.kind is string
        && isKnownBackendEventKind(request.resource.data.kind)
        && request.resource.data.syncStatus == 'acknowledged'
        && request.resource.data.idempotencyKey is string
        && request.resource.data.idempotencyKey == userId + "-" + request.resource.data.kind + "-" + request.resource.data.entityID
        && request.resource.data.occurredAt is timestamp
        && request.resource.data.retryCount is int
        && (!request.resource.data.keys().hasAny(['lastAttemptAt'])
          || request.resource.data.lastAttemptAt is timestamp)
        && hasSafeBackendEventSummary()
        && request.resource.data.acceptedAt is timestamp;
    }

    match /users/{userId} {
      allow read: if isUser(userId);
      allow create, update: if isUser(userId) && isSafeUserDocument(userId);
      allow delete: if false;

      match /backendEvents/{eventId} {
        allow read: if isUser(userId);
        allow create, update: if isUser(userId)
          && isSafeBackendEventDocument(userId, eventId);
        allow delete: if false;
      }

      match /profiles/{profileId} {
        allow read: if isUser(userId);
        allow create, update: if isUser(userId)
          && isSafeCareerGraphDocument('profiles', userId, profileId);
        allow delete: if false;
      }

      match /goals/{goalId} {
        allow read: if isUser(userId);
        allow create, update: if isUser(userId)
          && isSafeCareerGraphDocument('goals', userId, goalId);
        allow delete: if false;
      }

      match /targetRoles/{roleId} {
        allow read: if isUser(userId);
        allow create, update: if isUser(userId)
          && isSafeCareerGraphDocument('targetRoles', userId, roleId);
        allow delete: if false;
      }

      match /proofAttachments/{attachmentId} {
        allow read: if isUser(userId);
        allow create, update: if isUser(userId)
          && isSafeProofAttachmentDocument(userId, attachmentId);
        allow delete: if false;
      }

      match /proofRecords/{proofId} {
        allow read: if isUser(userId);
        allow create, update: if isUser(userId)
          && isSafeProofRecordDocument(userId)
          && hasDocumentPath('proofRecords', userId, proofId);
        allow delete: if false;
      }

      match /outcomes/{outcomeId} {
        allow read: if isUser(userId);
        allow create, update: if isUser(userId)
          && isSafeCareerGraphDocument('outcomes', userId, outcomeId);
        allow delete: if false;
      }

      match /readinessSnapshots/{snapshotId} {
        allow read: if isUser(userId);
        allow create, update: if isUser(userId)
          && isSafeCareerGraphDocument('readinessSnapshots', userId, snapshotId);
        allow delete: if false;
      }

      match /{document=**} {
        allow read: if isUser(userId);
        allow create, update: if false;
        allow delete: if false;
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
