rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isUser(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function hasTopLevelOwner(userId) {
      return !request.resource.data.keys().hasAny(['ownerUserID'])
        || request.resource.data.ownerUserID == userId;
    }

    function hasMetadataOwner(userId) {
      return !request.resource.data.keys().hasAny(['metadata'])
        || !request.resource.data.metadata.keys().hasAny(['ownerUserID'])
        || request.resource.data.metadata.ownerUserID == userId;
    }

    function noExternalActionWrite() {
      return !request.resource.data.keys().hasAny(['externalActionTaken'])
        || request.resource.data.externalActionTaken == false;
    }

    function noUnsafeBackendSyncStatusWrite() {
      return !request.resource.data.keys().hasAny(['syncStatus']);
    }

    function noBackendEventBypassWrite() {
      return !request.resource.data.keys().hasAny(['idempotencyKey']);
    }

    function noLocalFilePathWrite() {
      return !request.resource.data.keys().hasAny(['localRelativePath']);
    }

    function noConsentBypassWrite() {
      return !request.resource.data.keys().hasAny([
        'allowsPrivateEvidenceCloudSync',
        'consentTextVersion',
        'acceptedAt'
      ]);
    }

    function isSafeUserDocument(userId) {
      return hasTopLevelOwner(userId)
        && hasMetadataOwner(userId)
        && noExternalActionWrite()
        && noUnsafeBackendSyncStatusWrite()
        && noBackendEventBypassWrite()
        && noLocalFilePathWrite()
        && noConsentBypassWrite();
    }

    function hasProofAttachmentPath(userId, attachmentId) {
      return request.resource.data.storagePath == "users/" + userId + "/proofAttachments/" + attachmentId
        && request.resource.data.collectionPath == "users/" + userId + "/proofAttachments"
        && request.resource.data.documentPath == "users/" + userId + "/proofAttachments/" + attachmentId
        && request.resource.data.metadata.localID == attachmentId;
    }

    function hasClientProofUploadState() {
      return request.resource.data.uploadStatus == 'pendingUpload'
        && !request.resource.data.keys().hasAny(['uploadReceipt']);
    }

    function isSafeProofAttachmentDocument(userId, attachmentId) {
      return isSafeUserDocument(userId)
        && hasAcceptedPrivateEvidenceCloudSyncConsent(userId)
        && hasProofAttachmentPath(userId, attachmentId)
        && request.resource.data.contentType is string
        && request.resource.data.byteCount is int
        && hasClientProofUploadState();
    }

    function isSafeProofRecordDocument(userId) {
      return isSafeUserDocument(userId)
        && hasAcceptedPrivateEvidenceCloudSyncConsent(userId)
        && !request.resource.data.keys().hasAny(['attachments']);
    }

    function hasNoPrivateGoalContextOrAcceptedConsent(userId) {
      return !request.resource.data.keys().hasAny(['privateContext'])
        || hasAcceptedPrivateEvidenceCloudSyncConsent(userId);
    }

    function hasNoPrivateOutcomeOrAcceptedConsent(userId) {
      return (request.resource.data.keys().hasAny(['isPrivate'])
          && request.resource.data.isPrivate == false)
        || hasAcceptedPrivateEvidenceCloudSyncConsent(userId);
    }

    function hasAcceptedPrivateEvidenceCloudSyncConsent(userId) {
      return exists(/databases/$(database)/documents/users/$(userId)/consents/privateEvidenceCloudSync)
        && get(/databases/$(database)/documents/users/$(userId)/consents/privateEvidenceCloudSync).data.schemaVersion == 1
        && get(/databases/$(database)/documents/users/$(userId)/consents/privateEvidenceCloudSync).data.ownerUserID == userId
        && get(/databases/$(database)/documents/users/$(userId)/consents/privateEvidenceCloudSync).data.status == 'accepted'
        && get(/databases/$(database)/documents/users/$(userId)/consents/privateEvidenceCloudSync).data.allowsPrivateEvidenceCloudSync == true
        && get(/databases/$(database)/documents/users/$(userId)/consents/privateEvidenceCloudSync).data.consentTextVersion == 'private-evidence-cloud-sync-v1';
    }

    function hasDocumentPath(collectionName, userId, documentId) {
      return request.resource.data.collectionPath == "users/" + userId + "/" + collectionName
        && request.resource.data.documentPath == "users/" + userId + "/" + collectionName + "/" + documentId;
    }

    function isSafeCareerGraphDocument(collectionName, userId, documentId) {
      return isSafeUserDocument(userId)
        && hasDocumentPath(collectionName, userId, documentId);
    }

    match /users/{userId} {
      allow read: if isUser(userId);
      allow create, update: if isUser(userId) && isSafeUserDocument(userId);
      allow delete: if false;

      match /backendEvents/{eventId} {
        allow read: if isUser(userId);
        allow delete: if false;
        allow create, update: if false;
      }

      match /consents/{consentId} {
        allow read: if isUser(userId);
        allow create, update: if false;
        allow delete: if false;
      }

      match /profiles/{profileId} {
        allow read: if isUser(userId);
        allow create, update: if isUser(userId)
          && isSafeCareerGraphDocument('profiles', userId, profileId);
        allow delete: if false;
      }

      match /goals/{goalId} {
        allow read: if isUser(userId);
        allow create, update: if isUser(userId)
          && isSafeCareerGraphDocument('goals', userId, goalId)
          && hasNoPrivateGoalContextOrAcceptedConsent(userId);
        allow delete: if false;
      }

      match /targetRoles/{roleId} {
        allow read: if isUser(userId);
        allow create, update: if isUser(userId)
          && isSafeCareerGraphDocument('targetRoles', userId, roleId);
        allow delete: if false;
      }

      match /proofAttachments/{attachmentId} {
        allow read: if isUser(userId);
        allow create: if isUser(userId)
          && isSafeProofAttachmentDocument(userId, attachmentId);
        allow update: if false;
        allow delete: if false;
      }

      match /proofRecords/{proofId} {
        allow read: if isUser(userId);
        allow create, update: if isUser(userId)
          && isSafeProofRecordDocument(userId)
          && hasDocumentPath('proofRecords', userId, proofId);
        allow delete: if false;
      }

      match /outcomes/{outcomeId} {
        allow read: if isUser(userId);
        allow create, update: if isUser(userId)
          && isSafeCareerGraphDocument('outcomes', userId, outcomeId)
          && hasNoPrivateOutcomeOrAcceptedConsent(userId);
        allow delete: if false;
      }

      match /readinessSnapshots/{snapshotId} {
        allow read: if isUser(userId);
        allow create, update: if isUser(userId)
          && isSafeCareerGraphDocument('readinessSnapshots', userId, snapshotId);
        allow delete: if false;
      }

      match /{document=**} {
        allow read: if isUser(userId);
        allow create, update: if false;
        allow delete: if false;
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
