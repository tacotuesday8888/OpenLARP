rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function isUser(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function hasOpenLARPProofMetadata() {
      return request.resource.metadata.keys().hasAll([
        'ownerUserID',
        'proofID',
        'attachmentID',
        'idempotencyKey'
      ])
        && request.resource.metadata.keys().hasOnly([
          'ownerUserID',
          'proofID',
          'attachmentID',
          'idempotencyKey'
        ])
        && request.resource.metadata.ownerUserID is string
        && request.resource.metadata.ownerUserID.size() > 0
        && request.resource.metadata.ownerUserID.size() <= 128
        && request.resource.metadata.proofID is string
        && request.resource.metadata.proofID.size() > 0
        && request.resource.metadata.proofID.size() <= 128
        && request.resource.metadata.attachmentID is string
        && request.resource.metadata.attachmentID.size() > 0
        && request.resource.metadata.attachmentID.size() <= 128
        && request.resource.metadata.idempotencyKey is string
        && request.resource.metadata.idempotencyKey.size() > 0
        && request.resource.metadata.idempotencyKey.size() <= 257;
    }

    function isAllowedProofContentType() {
      return request.resource.contentType in [
        'image/png',
        'image/jpeg',
        'image/heic',
        'image/heif',
        'application/pdf',
        'text/plain'
      ];
    }

    function privateEvidenceCloudSyncConsentPath(userId) {
      return /databases/(default)/documents/users/$(userId)/consents/privateEvidenceCloudSync;
    }

    function accountDeletionRequestPath(userId) {
      return /databases/(default)/documents/_accountDeletionRequests/$(userId);
    }

    function hasAccountDeletionRequest(userId) {
      return firestore.exists(accountDeletionRequestPath(userId));
    }

    function hasAcceptedPrivateEvidenceCloudSyncConsent(userId) {
      return firestore.exists(privateEvidenceCloudSyncConsentPath(userId))
        && firestore.get(privateEvidenceCloudSyncConsentPath(userId)).data.schemaVersion == 1
        && firestore.get(privateEvidenceCloudSyncConsentPath(userId)).data.ownerUserID == userId
        && firestore.get(privateEvidenceCloudSyncConsentPath(userId)).data.status == 'accepted'
        && firestore.get(privateEvidenceCloudSyncConsentPath(userId)).data.allowsPrivateEvidenceCloudSync == true
        && firestore.get(privateEvidenceCloudSyncConsentPath(userId)).data.consentTextVersion == 'private-evidence-cloud-sync-v1';
    }

    match /users/{userId}/proofAttachments/{attachmentId} {
      allow read: if isUser(userId);
      allow create: if resource == null
        && isUser(userId)
        && !hasAccountDeletionRequest(userId)
        && hasAcceptedPrivateEvidenceCloudSyncConsent(userId)
        && request.resource.size < 10 * 1024 * 1024
        && isAllowedProofContentType()
        && hasOpenLARPProofMetadata()
        && request.resource.metadata.ownerUserID == userId
        && request.resource.metadata.attachmentID == attachmentId
        && request.resource.metadata.idempotencyKey == userId + "-" + attachmentId;
      allow delete: if false;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
