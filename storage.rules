rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function isUser(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function hasOpenLARPProofMetadata() {
      return request.resource.metadata.keys().hasAll([
        'ownerUserID',
        'proofID',
        'attachmentID',
        'idempotencyKey'
      ]);
    }

    match /users/{userId}/proofAttachments/{attachmentId} {
      allow read: if isUser(userId);
      allow create: if resource == null
        && isUser(userId)
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*|application/pdf|text/plain')
        && hasOpenLARPProofMetadata()
        && request.resource.metadata.ownerUserID == userId
        && request.resource.metadata.proofID is string
        && request.resource.metadata.attachmentID == attachmentId
        && request.resource.metadata.idempotencyKey == userId + "-" + attachmentId;
      allow delete: if false;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
