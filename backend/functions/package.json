{
  "name": "@openlarp/firebase-functions",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "engines": {
    "node": "22"
  },
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --format=esm --target=node22 --external:firebase-admin --external:firebase-functions --external:genkit --outfile=dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "firebase-admin": "14.0.0",
    "firebase-functions": "7.2.5",
    "genkit": "1.37.0"
  },
  "devDependencies": {
    "@types/node": "22.19.21",
    "esbuild": "0.28.1",
    "typescript": "5.8.3",
    "vitest": "4.1.9"
  }
}
